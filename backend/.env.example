# Database
DATABASE_URL=sqlite:///./film_archive.db
# For PostgreSQL: postgresql://user:password@localhost/film_archive

# JWT
SECRET_KEY=your-super-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS - 包含 null 以支持直接打开文件
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500,http://localhost:8000,null

# App
DEBUG=true
